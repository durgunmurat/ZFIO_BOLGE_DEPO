<mvc:View
    controllerName="com.sut.bolgeyonetim.controller.ReturnCount"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page
        title="İade Sayım"
        showNavButton="true"
        navButtonPress="onNavBack">
        <customHeader>
            <Toolbar>
                <Button
                    icon="sap-icon://nav-back"
                    type="Transparent"
                    press="onNavBack"/>
                <Title text="İade Sayım"/>
                <ToolbarSpacer/>
                <DatePicker
                    visible="false"
                    id="idReturnDateFilter"
                    value="{filterModel>/selectedDate}"
                    displayFormat="dd.MM.yyyy"
                    valueFormat="yyyy-MM-dd"
                    change="onDateChange"
                    width="10rem"/>
                <Label
                    visible="false"
                    text="{sessionModel>/Login/WarehouseNum}"
                    class="sapUiSmallMarginBegin"/>
            </Toolbar>
        </customHeader>
        <content>
            <IconTabBar
                id="idReturnTypeFilterBar"
                selectedKey="MD"
                select="onTypeFilterSelect"
                class="sapUiResponsiveContentPadding returnCountTypeBar"
                upperCase="false"
                stretchContentHeight="false"
                expandable="false">
                <items>
                    <IconTabFilter
                        key="MD"
                        text="Monodistribütör"
                        count="{returnCountModel>/mdCount}"
                        icon="sap-icon://supplier"/>
                    <IconTabFilter
                        key="OP"
                        text="Organize Dağıtım"
                        count="{returnCountModel>/opCount}"
                        icon="sap-icon://tree"/>
                </items>
            </IconTabBar>

            <IconTabBar
                id="idReturnStatusFilterBar"
                selectedKey="pending"
                select="onStatusFilterSelect"
                class="returnCountStatusBar"
                upperCase="false"
                stretchContentHeight="false"
                expandable="false">
                <items>
                    <IconTabFilter
                        id="idReturnPendingTab"
                        key="pending"
                        text="Bekleyen İadeler"
                        count="{returnCountModel>/pendingCount}"/>
                    <IconTabFilter
                        id="idReturnCompletedTab"
                        key="completed"
                        text="Tamamlanan Sayımlar"
                        count="{returnCountModel>/completedCount}"/>
                </items>
            </IconTabBar>

            <List
                id="idReturnRepresentativeList"
                items="{returnCountModel>/visibleGroups}"
                noDataText="Seçilen tarih ve depo için iade kaydı bulunamadı">
                <items>
                    <CustomListItem>
                        <Panel
                            expandable="true"
                            expanded="{returnCountModel>expanded}"
                            class="sapUiSmallMarginBottom">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <core:Icon
                                        src="sap-icon://employee"
                                        size="1.5rem"
                                        color="#0854A0"/>
                                    <Title
                                        text="{returnCountModel>PlasiyerDisplay} - {returnCountModel>PlasiyerName}"
                                        level="H3"
                                        class="sapUiTinyMarginBegin"/>
                                    <ToolbarSpacer/>
                                    <CheckBox
                                        text="Plasiyerleri seç"
                                        selected="{= ${returnCountModel>selectionScope} === 'P' }"
                                        select="onSelectionScopeSelect">
                                        <customData>
                                            <core:CustomData key="selectionScope" value="P"/>
                                        </customData>
                                    </CheckBox>
                                    <CheckBox
                                        text="Müşterileri seç"
                                        selected="{= ${returnCountModel>selectionScope} === 'M' }"
                                        select="onSelectionScopeSelect">
                                        <customData>
                                            <core:CustomData key="selectionScope" value="M"/>
                                        </customData>
                                    </CheckBox>
                                    <CheckBox
                                        text="Hepsini seç"
                                        selected="{= ${returnCountModel>selectionScope} === 'ALL' }"
                                        select="onSelectionScopeSelect">
                                        <customData>
                                            <core:CustomData key="selectionScope" value="ALL"/>
                                        </customData>
                                    </CheckBox>
                                    <Button
                                        icon="sap-icon://accept"
                                        text="Sayımı Onayla"
                                        type="Emphasized"
                                        press="onApproveCountPress"
                                        visible="{= !${returnCountModel>isCompleted} }"
                                        class="sapUiTinyMarginBegin"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            <content>
                                <VBox>
                                    <List
                                        items="{returnCountModel>Waybills}"
                                        noDataText="İrsaliye bulunamadı">
                                        <items>
                                            <CustomListItem>
                                                <HBox
                                                    alignItems="Center"
                                                    width="100%">
                                                    <CheckBox
                                                        selected="{returnCountModel>selected}"
                                                        select="onWaybillSelect"/>
                                                    <VBox class="sapUiTinyMarginBegin">
                                                        <Text text="İrsaliye No: {returnCountModel>IrsNo}"/>
                                                        <Text
                                                            text="{returnCountModel>ReturnTypeText}"
                                                            class="sapUiTinyMarginTop"/>
                                                    </VBox>
                                                </HBox>
                                            </CustomListItem>
                                        </items>
                                    </List>

                                    <Table
                                        items="{returnCountModel>Items}"
                                        inset="false"
                                        fixedLayout="true"
                                        growing="true"
                                        growingThreshold="50"
                                        width="100%"
                                        noDataText="Sayım için en az bir irsaliye seçin"
                                        class="sapUiSmallMarginTop returnCountTable">
                                        <columns>
                                            <Column width="40%">
                                                <Text text="ÜRÜN"/>
                                            </Column>
                                            <Column width="12%" hAlign="End">
                                                <Text text="TOPLAM"/>
                                            </Column>
                                            <Column width="16%" hAlign="End">
                                                <Text text="FİRE"/>
                                            </Column>
                                            <Column width="16%" hAlign="End">
                                                <Text text="KALİTE"/>
                                            </Column>
                                            <Column width="16%" hAlign="End">
                                                <Text text="SATILABİLİR"/>
                                            </Column>
                                        </columns>
                                        <items>
                                            <ColumnListItem
                                                highlight="{= ${returnCountModel>MengeSayim} !== ${returnCountModel>MengeSiparis} ? 'Error' : 'None' }">
                                                <cells>
                                                    <ObjectIdentifier
                                                        title="{returnCountModel>Maktx}"
                                                        text="{returnCountModel>MaterialDisplayCode}"
                                                        class="returnCountMaterial"/>
                                                    <ObjectNumber
                                                        number="{returnCountModel>MengeSayim}"
                                                        unit="{returnCountModel>Meins}"
                                                        state="{= ${returnCountModel>MengeSayim} !== ${returnCountModel>MengeSiparis} ? 'Error' : 'None' }"/>
                                                    <Input
                                                        value="{returnCountModel>MengeFire}"
                                                        type="Number"
                                                        width="100%"
                                                        textAlign="End"
                                                        editable="{= !${returnCountModel>_completed} }"
                                                        change="onCountChange"/>
                                                    <Input
                                                        value="{returnCountModel>MengeKalite}"
                                                        type="Number"
                                                        width="100%"
                                                        textAlign="End"
                                                        editable="{= !${returnCountModel>_completed} }"
                                                        change="onCountChange"/>
                                                    <Input
                                                        value="{returnCountModel>MengeSatilab}"
                                                        type="Number"
                                                        width="100%"
                                                        textAlign="End"
                                                        editable="{= !${returnCountModel>_completed} }"
                                                        change="onCountChange"/>
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </VBox>
                            </content>
                        </Panel>
                    </CustomListItem>
                </items>
            </List>
        </content>
    </Page>
</mvc:View>
